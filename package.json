{
  "name": "ssampin",
  "version": "1.10.5",
  "description": "쌤핀 - 교사용 데스크톱 대시보드",
  "private": true,
  "license": "GPL-3.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"node scripts/electron-dev.mjs\"",
    "build": "tsc -b && vite build && node scripts/build-electron.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "embed": "tsx scripts/embed-docs.ts --all",
    "embed:dry": "tsx scripts/embed-docs.ts --all --dry-run",
    "embed:file": "tsx scripts/embed-docs.ts --file",
    "test:chatbot": "tsx scripts/test-chatbot.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "dev:mobile": "vite --config vite.mobile.config.ts --port 5174",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "preview:mobile": "vite preview --config vite.mobile.config.ts",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:dmg": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@blocknote/ariakit": "~0.47.3",
    "@blocknote/core": "~0.47.3",
    "@blocknote/react": "~0.47.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.0.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@pdfme/common": "^6.0.6",
    "@pdfme/generator": "^6.0.6",
    "@supabase/supabase-js": "^2.49.0",
    "@ubermensch1218/hwpxcore": "^0.1.3",
    "cloudflared": "^0.7.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "fabric": "^7.2.0",
    "idb": "^8.0.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.5.3",
    "ws": "^8.19.0",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.19",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0"
  }
}
